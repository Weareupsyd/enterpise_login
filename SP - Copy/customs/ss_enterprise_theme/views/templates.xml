<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Client action to show the Enterprise Home Menu -->
    <record id="action_ss_enterprise_home_menu" model="ir.actions.client">
        <field name="name">Enterprise Home Menu</field>
        <field name="tag">ss_enterprise_home_menu</field>
    </record>

    <template id="ss_enterprise_home_menu_template">
        <t t-name="ss_enterprise_theme.HomeMenu">
            <div class="ss-enterprise-home-menu o_container">
                <div class="ss-enterprise-home-menu__header">
                    <t t-component="ss_enterprise_theme.SearchBar" t-props="{ value: this.state?.searchValue || '', onSearch: this.onSearch.bind(this) }"/>
                    <t t-component="ss_enterprise_theme.ThemeManager" t-props="{ selectedTheme: this.state?.selectedTheme || 'light', onSelect: this.onThemeSelected.bind(this) }"/>
                </div>
                <t t-component="ss_enterprise_theme.AppGrid" t-props="{ apps: this.filteredApps, onDragStart: this.onDragStart.bind(this), onDragOver: this.onDragOver.bind(this), onDrop: this.onDrop.bind(this) }"/>
            </div>
        </t>
    </template>

    <template t-name="ss_enterprise_theme.SearchBar">
        <div class="ss-search-bar">
            <input
                class="ss-search-input"
                type="text"
                placeholder="Search apps..."
                t-on-input="this.onInput"
                t-att-value="this.props.value"
            />
        </div>
    </template>

    <template t-name="ss_enterprise_theme.ThemeManager">
        <div class="ss-theme-manager">
            <button type="button" t-on-click="() => this.selectTheme('light')" t-att-class="'ss-theme-button ' + (this.props.selectedTheme === 'light' ? 'active' : '')">Light</button>
            <button type="button" t-on-click="() => this.selectTheme('dark')" t-att-class="'ss-theme-button ' + (this.props.selectedTheme === 'dark' ? 'active' : '')">Dark</button>
            <button type="button" t-on-click="() => this.selectTheme('glass')" t-att-class="'ss-theme-button ' + (this.props.selectedTheme === 'glass' ? 'active' : '')">Glass</button>
        </div>
    </template>

    <template t-name="ss_enterprise_theme.AppGrid">
        <div class="ss-app-grid">
            <t t-foreach="this.props.apps" t-as="app" t-key="app.id">
                <t t-component="ss_enterprise_theme.AppTile" t-props="{ app: app, onDragStart: this.props.onDragStart, onDragOver: this.props.onDragOver, onDrop: this.props.onDrop }"/>
            </t>
        </div>
    </template>

    <template t-name="ss_enterprise_theme.AppTile">
        <div class="ss-app-tile"
             draggable="true"
             t-on-dragstart="(ev) => this.onDragStart(ev, this.props.app.id)"
             t-on-dragover="this.onDragOver"
             t-on-drop="(ev) => this.onDrop(ev, this.props.app.id)">
            <div class="ss-app-tile__icon">
                <img t-if="this.props.app.webIconData" t-att-src="this.props.app.webIconData" alt="Icon"/>
                <div t-if="!this.props.app.webIconData" class="ss-app-tile__fallback-icon"/>
            </div>
            <div class="ss-app-tile__name">
                <t t-esc="this.props.app.name"/>
            </div>
        </div>
    </template>
</odoo>
